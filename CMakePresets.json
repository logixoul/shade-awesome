{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "windows",
      "inherits": "base",
      "displayName": "Windows MSVC",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux",
      "inherits": "base",
      "displayName": "Linux Ninja",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "mac",
      "inherits": "base",
      "displayName": "macOS Ninja",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-release", "configurePreset": "windows", "configuration": "Release" },
    { "name": "linux-release",   "configurePreset": "linux",   "configuration": "Release" },
    { "name": "mac-release",     "configurePreset": "mac",     "configuration": "Release" }
  ]
}